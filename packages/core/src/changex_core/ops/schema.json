{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://changex.dev/schema/0.3/changex.json",
  "title": "ChangeX v0.3 journal schema",
  "description": "Schemas for the .changex header, op events, and the frozen v0.3 op set (docx text/structure ops, the docx run-format + paragraph-move ops, the xlsx/csv cell+row ops and pptx slide+shape ops). No op kinds remain reserved as of v0.3.",
  "definitions": {
    "provenance": {
      "type": "object",
      "required": ["ts", "session_id", "provenance_source"],
      "properties": {
        "ts": { "type": "string" },
        "session_id": { "type": "string" },
        "tool_call_id": { "type": ["string", "null"] },
        "client_name": { "type": ["string", "null"] },
        "client_version": { "type": ["string", "null"] },
        "agent": { "type": ["string", "null"] },
        "vendor": { "type": ["string", "null"] },
        "turn_id": { "type": ["string", "null"] },
        "prompt_sha256": { "type": ["string", "null"] },
        "rationale": { "type": ["string", "null"] },
        "provenance_source": { "type": "string", "enum": ["observed", "declared"] }
      },
      "additionalProperties": false
    },
    "target": {
      "type": "object",
      "required": ["node_id", "node_kind", "path"],
      "properties": {
        "node_id": { "type": "string" },
        "node_kind": { "type": "string" },
        "path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "op_text_insert": {
      "type": "object",
      "required": ["kind", "node_id", "before_anchor", "text"],
      "properties": {
        "kind": { "const": "text.insert" },
        "node_id": { "type": "string" },
        "before_anchor": { "type": ["string", "null"] },
        "text": { "type": "string" }
      },
      "additionalProperties": false
    },
    "op_text_delete": {
      "type": "object",
      "required": ["kind", "node_id", "before"],
      "properties": {
        "kind": { "const": "text.delete" },
        "node_id": { "type": "string" },
        "before": { "type": "string" }
      },
      "additionalProperties": false
    },
    "op_text_replace": {
      "type": "object",
      "required": ["kind", "node_id", "before", "after"],
      "properties": {
        "kind": { "const": "text.replace" },
        "node_id": { "type": "string" },
        "before": { "type": "string" },
        "after": { "type": "string" }
      },
      "additionalProperties": false
    },
    "op_node_insert": {
      "type": "object",
      "required": ["kind", "node_kind", "position", "value"],
      "properties": {
        "kind": { "const": "node.insert" },
        "node_kind": { "type": "string" },
        "position": { "type": "integer", "minimum": 0 },
        "value": { "type": "object" }
      },
      "additionalProperties": false
    },
    "op_node_delete": {
      "type": "object",
      "required": ["kind", "node_id", "value"],
      "properties": {
        "kind": { "const": "node.delete" },
        "node_id": { "type": "string" },
        "value": { "type": "object" }
      },
      "additionalProperties": false
    },
    "op_style_change": {
      "type": "object",
      "required": ["kind", "node_id", "style", "before"],
      "properties": {
        "kind": { "const": "style.change" },
        "node_id": { "type": "string" },
        "style": { "type": "string" },
        "before": { "type": "string" }
      },
      "additionalProperties": false
    },
    "op_format_run": {
      "type": "object",
      "required": ["kind", "node_id", "props", "before"],
      "properties": {
        "kind": { "const": "format.run" },
        "node_id": { "type": "string" },
        "props": { "type": "object" },
        "before": { "type": "object" }
      },
      "additionalProperties": false
    },
    "op_node_move": {
      "type": "object",
      "required": ["kind", "node_id", "from_index", "to_index"],
      "properties": {
        "kind": { "const": "node.move" },
        "node_id": { "type": "string" },
        "from_index": { "type": "integer", "minimum": 0 },
        "to_index": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "op_cell_set": {
      "type": "object",
      "required": ["kind", "sheet", "ref", "before", "after"],
      "properties": {
        "kind": { "const": "cell.set" },
        "sheet": { "type": "string" },
        "ref": { "type": "string" },
        "before": { "type": "string" },
        "after": { "type": "string" }
      },
      "additionalProperties": false
    },
    "op_formula_set": {
      "type": "object",
      "required": ["kind", "sheet", "ref", "before", "after"],
      "properties": {
        "kind": { "const": "formula.set" },
        "sheet": { "type": "string" },
        "ref": { "type": "string" },
        "before": { "type": "string" },
        "after": { "type": "string" }
      },
      "additionalProperties": false
    },
    "op_row_insert": {
      "type": "object",
      "required": ["kind", "sheet", "at"],
      "properties": {
        "kind": { "const": "row.insert" },
        "sheet": { "type": "string" },
        "at": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "op_row_delete": {
      "type": "object",
      "required": ["kind", "sheet", "at", "value"],
      "properties": {
        "kind": { "const": "row.delete" },
        "sheet": { "type": "string" },
        "at": { "type": "integer" },
        "value": { "type": "array" }
      },
      "additionalProperties": false
    },
    "op_slide_insert": {
      "type": "object",
      "required": ["kind", "at", "value"],
      "properties": {
        "kind": { "const": "slide.insert" },
        "at": { "type": "integer" },
        "value": { "type": "object" }
      },
      "additionalProperties": false
    },
    "op_slide_delete": {
      "type": "object",
      "required": ["kind", "at", "value"],
      "properties": {
        "kind": { "const": "slide.delete" },
        "at": { "type": "integer" },
        "value": { "type": "object" }
      },
      "additionalProperties": false
    },
    "op_shape_edit": {
      "type": "object",
      "required": ["kind", "slide", "shape_id", "op"],
      "properties": {
        "kind": { "const": "shape.edit" },
        "slide": { "type": "integer" },
        "shape_id": { "type": "string" },
        "op": { "type": "object" }
      },
      "additionalProperties": false
    },
    "op": {
      "oneOf": [
        { "$ref": "#/definitions/op_text_insert" },
        { "$ref": "#/definitions/op_text_delete" },
        { "$ref": "#/definitions/op_text_replace" },
        { "$ref": "#/definitions/op_node_insert" },
        { "$ref": "#/definitions/op_node_delete" },
        { "$ref": "#/definitions/op_style_change" },
        { "$ref": "#/definitions/op_format_run" },
        { "$ref": "#/definitions/op_node_move" },
        { "$ref": "#/definitions/op_cell_set" },
        { "$ref": "#/definitions/op_formula_set" },
        { "$ref": "#/definitions/op_row_insert" },
        { "$ref": "#/definitions/op_row_delete" },
        { "$ref": "#/definitions/op_slide_insert" },
        { "$ref": "#/definitions/op_slide_delete" },
        { "$ref": "#/definitions/op_shape_edit" }
      ]
    },
    "header": {
      "type": "object",
      "required": ["type", "changex_version", "op_schema_version", "doc", "session"],
      "properties": {
        "type": { "const": "header" },
        "changex_version": { "type": "string" },
        "op_schema_version": { "type": "string" },
        "doc": {
          "type": "object",
          "required": ["baseline_sha256"],
          "properties": {
            "filename": { "type": ["string", "null"] },
            "format": { "type": "string" },
            "baseline_sha256": { "type": "string" },
            "baseline_uri": { "type": ["string", "null"] }
          }
        },
        "session": {
          "type": "object",
          "required": ["session_id"],
          "properties": {
            "session_id": { "type": "string" },
            "started_at": { "type": "string" },
            "capture_mode": { "type": "string", "enum": ["active", "passive"] }
          }
        },
        "node_id_map": { "type": "object" },
        "prev_hash": { "type": "null" }
      }
    },
    "event": {
      "type": "object",
      "required": ["type", "op_id", "seq", "ts", "op_schema_version", "provenance", "target", "op", "hash", "prev_hash"],
      "properties": {
        "type": { "const": "op" },
        "op_id": { "type": "string" },
        "seq": { "type": "integer", "minimum": 1 },
        "ts": { "type": "string" },
        "op_schema_version": { "type": "string" },
        "provenance": { "$ref": "#/definitions/provenance" },
        "target": { "$ref": "#/definitions/target" },
        "op": { "$ref": "#/definitions/op" },
        "hash": { "type": "string" },
        "prev_hash": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "x-reserved-ops-appendix": {
    "description": "No op kinds remain reserved as of v0.3. The docx run-format (format.run) and paragraph-move (node.move) ops — the last reserved kinds in v0.2 — are now part of the frozen op set above, alongside the xlsx/csv/pptx ops un-reserved in v0.2.",
    "kinds": []
  }
}
